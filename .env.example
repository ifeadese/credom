# FormBold form endpoint that the contact form POSTs to.
# Create a form at https://formbold.com, set it to deliver to
# ifeoluwaadese@gmail.com, enable spam protection, then paste the
# endpoint URL here (and into .env.local for local development).
# Exposed to the browser (NEXT_PUBLIC_) because the form submits client-side.
NEXT_PUBLIC_FORMBOLD_ENDPOINT=https://formbold.com/s/your-form-id
